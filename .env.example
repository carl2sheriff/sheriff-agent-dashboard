# ─── Backend ────────────────────────────────────────────────────────────────

# Port du serveur Express
PORT=3001

# Token API Railway pour récupérer les statuts de déploiement
# Générer sur: https://railway.app/account/tokens
RAILWAY_API_TOKEN=your_railway_api_token_here

# URLs des agents (optionnel — déjà hardcodées dans config/agents.js)
AGENT_CA_MARGE_URL=https://agent-repartition-ca-marge-production.up.railway.app
AGENT_SCOUTING_URL=https://agent-scouting-talent-production.up.railway.app

# URL du frontend (CORS) — laisser vide en local
FRONTEND_URL=

# Environnement (development / production)
NODE_ENV=development

# ─── Frontend ────────────────────────────────────────────────────────────────

# URL du backend API (depuis le navigateur)
# En local: http://localhost:3001
# En production: URL publique Railway du backend
VITE_API_URL=http://localhost:3001
